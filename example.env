PORT=4321

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/moviedb

# A strong, randomly generated string used to sign JWT session tokens (min 16 chars)
JWT_SECRET=change_me_to_a_strong_random_secret

# A separate strong string used to sign/verify httpOnly cookies (min 16 chars)
COOKIE_SECRET=change_me_to_another_strong_secret

# React frontend origin (used for CORS credentials support)
CLIENT_ORIGIN=http://localhost:1234

# ── Email / SMTP (Nodemailer) ──────────────────────────────────────────────────
# Works with any SMTP provider: Gmail, SendGrid, Mailgun, Brevo, etc.
#
# Gmail example (use an App Password, not your account password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_app_password
# EMAIL_FROM=i99flix <noreply@i99flix.com>

# SendGrid example:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# EMAIL_FROM=i99flix <noreply@i99flix.com>

# For local development use Ethereal (https://ethereal.email) — free, no real emails sent.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=i99flix <noreply@i99flix.com>
