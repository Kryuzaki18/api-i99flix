PORT=4321

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/moviedb

# A strong, randomly generated string used to sign JWT session tokens (min 16 chars)
JWT_SECRET=change_me_to_a_strong_random_secret

# A separate strong string used to sign/verify httpOnly cookies (min 16 chars)
COOKIE_SECRET=change_me_to_another_strong_secret

# React frontend origin (used for CORS credentials support)
CLIENT_ORIGIN=http://localhost:1234

# Publicly accessible URL for the logo image used in email templates.
# On prod, point this to your CDN or static hosting URL (e.g. https://cdn.sample.com/my-logo.png).
# Locally it defaults to CLIENT_ORIGIN/my-logo.png.
LOGO_URL=http://localhost:1234/my-logo.png

TMDB_KEY=tmdb_key
TMDB_READ_ACCESS_TOKEN=tmdb_read_access_token

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier is 3,000 emails/month.
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=resend <onboarding@resend.dev>

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# The Firebase project ID (found in Firebase Console → Project Settings).
FIREBASE_PROJECT_ID=your-firebase-project-id
