PORT=4321

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/moviedb

# A strong, randomly generated string used to sign JWT session tokens (min 16 chars)
JWT_SECRET=change_me_to_a_strong_random_secret

# A separate strong string used to sign/verify httpOnly cookies (min 16 chars)
COOKIE_SECRET=change_me_to_another_strong_secret

# React frontend origin (used for CORS credentials support)
CLIENT_ORIGIN=http://localhost:1234
