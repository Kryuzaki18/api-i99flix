{
  "name": "api-movie",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pm2:start-prod": "pm2-runtime start ecosystem.config.cjs --env production",
    "pm2:start-local": "npm run build && pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop api",
    "pm2:restart": "pm2 restart api",
    "pm2:reload": "pm2 reload api",
    "pm2:delete": "pm2 delete api",
    "pm2:logs": "pm2 logs api",
    "pm2:status": "pm2 status",
    "pm2:monit": "pm2 monit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^6.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@google/generative-ai": "^0.24.1",
    "@sinclair/typebox": "^0.34.49",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "mongoose": "^9.6.2",
    "nodemailer": "^8.0.7",
    "pm2": "^7.0.1",
    "undici": "^8.2.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.6.2",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
